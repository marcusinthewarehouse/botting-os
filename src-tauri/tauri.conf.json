{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BottingOS",
  "version": "0.1.0",
  "identifier": "com.bottingos.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BottingOS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "category": "DeveloperTool",
    "shortDescription": "Command center for botting operations",
    "longDescription": "BottingOS is a desktop command center for managing botting operations including inventory tracking, order management, profit calculation, drop calendars, and more."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.bottingos.app/check/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": ""
    }
  }
}
